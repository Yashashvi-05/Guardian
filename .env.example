# GUARDIAN Fleet — Environment Variables
# Copy to .env and fill in your values before running anything.

# Required: OpenAI API key for Worker agents, CurriculumAgent, ComplianceSimulator
OPENAI_API_KEY=sk-your-key-here

# Optional: HuggingFace token for pushing trained models to Hub
HF_TOKEN=hf_your-token-here

# Optional: HuggingFace repo for auto-push after training
# Set to: "your-org/guardian-qwen2.5-7b-grpo"
HF_REPO=

# Optional: Path to a trained Guardian model checkpoint (overrides default base model)
GUARDIAN_MODEL=guardian/checkpoints/final

# Optional: HMAC secret for MCP proxy request signing
# Change this to a long random string in production
HMAC_SECRET=changeme-use-a-long-random-string-in-production

# Optional: Dashboard port (default 7860)
GUARDIAN_PORT=7860

# Optional: MCP upstream URL (the real MCP server to proxy to)
MCP_UPSTREAM_URL=http://localhost:8001

# Optional: Enable demo mode in dashboard (uses pre-recorded data, no model loading needed)
# Set to "1" for guaranteed-working demo; "0" for live inference
GUARDIAN_DEMO_MODE=0

# Optional: Log level
LOG_LEVEL=info
